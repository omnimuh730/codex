# Agent BFF — orchestrates codex-rs job-application agents for Athens
PORT=8780

# Athens-server base URL (resume generation for agent autobid)
ATHENS_SERVER_URL=http://127.0.0.1:7979

# Align with Athens-server (default AthensDB, not AIMS_local)
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=AthensDB

# codex-rs binary (build: cd codex/codex-rs && cargo build --release)
CODEX_BIN=../codex-rs/target/release/codex

# API keys are read from codex/.env (OPENAI_API_KEY, DEEPSEEK_API_KEY)
# OPENAI_MODEL=gpt-4o-mini
# AUTO_SUBMIT=true
# DEEPSEEK_PROXY_PORT=8788

# Prerequisites:
# - Built codex-rs binary at CODEX_BIN
# - codex/.env with API keys
# - codex/auto-apply/ with AGENTS.md (Playwright working dir)
# - account_info.autoBidProfile with applicant details
# - user_resumes collection in MongoDB (techStack + inline/GridFS file content)
